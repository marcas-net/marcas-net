{
  "$schema": "https://schema.railway.app/config/v2.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "volumes": [
      {
        "mountPath": "/app/uploads",
        "name": "uploads"
      }
    ]
  }
}
